# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_api_key_here"

# FIREBASE_SERVICE_ACCOUNT_PATH: Path to Firebase service account JSON for admin SDK token verification.
# Generate in Firebase Console > Project Settings > Service Accounts > Generate New Private Key.
# If not set, falls back to Application Default Credentials (e.g., when running via Firebase CLI).
# FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccountKey.json"

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"

# Node Environment
NODE_ENV="development"
PORT=3000

# Platform Support WhatsApp Number
VITE_WHATSAPP_SUPPORT_NUMBER="258849001000"
